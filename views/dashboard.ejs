<%- include('partials/header', { currentPage: 'dashboard' }) %>

<div class="page">
  <div class="container">

    <% if (flashSuccess) { %><div class="flash flash-success">✅ <%- flashSuccess %></div><% } %>
    <% if (flashError)   { %><div class="flash flash-error">⚠️ <%- flashError %></div><% } %>

    <!-- Hero greeting -->
    <div style="margin-bottom:28px;">
      <h1 style="font-size:1.6rem;font-weight:800">
        👋 Welcome, <span style="color:var(--gold)"><%= user.display_name %></span>
      </h1>
      <p class="text-muted mt-8">FIFA World Cup 2026 · All times in Kuwait Time</p>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value" style="color:var(--gold)">🏆 <%= stats.rank %></div>
        <div class="stat-label">Your Rank <small style="color:var(--muted)">/ <%= stats.totalUsers %></small></div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.totalPts %></div>
        <div class="stat-label">Total Points</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:var(--blue)"><%= stats.groupPts %></div>
        <div class="stat-label">Group Stage Pts</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:#a78bfa"><%= stats.knockoutPts %></div>
        <div class="stat-label">Knockout Pts</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:var(--gold)"><%= stats.bonusPts %></div>
        <div class="stat-label">Bonus Pts</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:var(--green)"><%= stats.correct %></div>
        <div class="stat-label">Correct Picks</div>
      </div>
    </div>

    <div style="display:grid;gap:24px;grid-template-columns:1fr 1fr;" class="dashboard-cols">

      <!-- Upcoming matches needing predictions -->
      <div>
        <div class="section-header">
          <div>
            <div class="section-title">⏳ Predict Now</div>
            <div class="section-subtitle">Open matches awaiting your prediction</div>
          </div>
          <a href="/matches" class="btn btn-secondary btn-sm">View All</a>
        </div>

        <% if (upcoming.length === 0) { %>
          <div class="card text-center text-muted" style="padding:28px">
            🎉 All upcoming matches are predicted!
          </div>
        <% } else { %>
          <div class="matches-grid">
            <% upcoming.forEach(m => { %>
            <div class="match-card">
              <div class="match-header">
                <span><%= m.group_name ? `Group ${m.group_name}` : m.round.toUpperCase() %></span>
                <span>⏰ <%= m.match_time_kwt %></span>
              </div>
              <div class="match-body">
                <div class="match-teams">
                  <div class="team-name team-a"><%= m.team_a %></div>
                  <div class="vs-badge">vs</div>
                  <div class="team-name team-b"><%= m.team_b %></div>
                </div>
                <div class="match-actions">
                  <a href="/matches/<%= m.id %>" class="btn btn-primary btn-sm">Predict</a>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Recent results -->
      <div>
        <div class="section-header">
          <div>
            <div class="section-title">📊 Recent Results</div>
            <div class="section-subtitle">Your latest points</div>
          </div>
          <a href="/matches?round=group" class="btn btn-secondary btn-sm">All Matches</a>
        </div>

        <% if (recent.length === 0) { %>
          <div class="card text-center text-muted" style="padding:28px">No results yet.</div>
        <% } else { %>
          <div class="matches-grid">
            <% recent.forEach(m => { %>
            <%
              let cardClass = '';
              if (m.prediction && m.result) {
                cardClass = m.pts.main > 0 ? (m.pts.bonus > 0 ? 'bonus' : 'correct') : 'incorrect';
              }
            %>
            <div class="match-card <%= cardClass %>">
              <div class="match-header">
                <span><%= m.group_name ? `Group ${m.group_name}` : m.round.toUpperCase() %></span>
                <span class="<%= m.pts && m.pts.main > 0 ? 'text-green' : (m.prediction ? 'text-red' : 'text-muted') %>">
                  <% if (m.prediction && m.result) { %>
                    +<%= (m.pts.main + m.pts.bonus) %> pts
                  <% } else { %>
                    No prediction
                  <% } %>
                </span>
              </div>
              <div class="match-body" style="padding:10px 16px">
                <div class="match-teams">
                  <div class="team-name team-a" style="font-size:.88rem"><%= m.team_a %></div>
                  <div class="result-badge">
                    <% if (m.result === 'team_a') { %>🏆<% } else if (m.result === 'draw') { %>🤝<% } else { %>🏆<% } %>
                  </div>
                  <div class="team-name team-b" style="font-size:.88rem"><%= m.team_b %></div>
                </div>
                <% if (m.prediction) { %>
                <div class="match-actions">
                  <% if (m.pts.main > 0) { %>
                    <span class="prediction-pill correct">✅ Correct</span>
                    <% if (m.pts.bonus > 0) { %><span class="prediction-pill saved">⭐ Bonus</span><% } %>
                  <% } else { %>
                    <span class="prediction-pill incorrect">❌ Wrong</span>
                  <% } %>
                </div>
                <% } %>
              </div>
            </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <div class="mt-24">
      <a href="/leaderboard" class="btn btn-secondary">🏆 Full Leaderboard</a>
      &nbsp;
      <a href="/awards" class="btn btn-secondary">🌟 Tournament Awards</a>
    </div>

  </div>
</div>

<style>
@media (max-width: 700px) { .dashboard-cols { grid-template-columns: 1fr !important; } }
</style>

<%- include('partials/footer') %>

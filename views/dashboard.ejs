<style>
@media (max-width: 700px) { .dashboard-cols { grid-template-columns: 1fr !important; } }
.text-red { color: #f87171 !important; }

/* Inline prediction buttons on dashboard */
.dash-pred-btn {
  flex: 1;
  padding: 6px 4px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-dim);
  font-size: .7rem;
  cursor: pointer;
  font-weight: 500;
  transition: border-color .15s, background .15s, color .15s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.dash-pred-btn:hover { border-color: rgba(255,255,255,.45); color: var(--text); }
.dash-pred-btn.dpb-sel { border-color: rgba(255,255,255,.75); background: rgba(255,255,255,.12); color: #fff; font-weight: 700; }
.match-card.needs-pick { border-left: 3px solid rgba(251,191,36,.5); }
</style>

<script>
// ── Batch predictions ─────────────────────────────────────────────────────────
var pendingPreds = {};

function selectPred(matchId, val, btn) {
  if (!pendingPreds[matchId]) pendingPreds[matchId] = {};
  pendingPreds[matchId].prediction = val;
  // update button highlight
  document.querySelectorAll('[data-match="' + matchId + '"]').forEach(function(b) {
    b.classList.remove('dpb-sel');
  });
  btn.classList.add('dpb-sel');
  // update status label
  var s = document.getElementById('status-' + matchId);
  if (s) { s.textContent = '· unsaved'; s.style.color = '#fbbf24'; }
  updateSaveBtn();
}

function selectAET(matchId, val) {
  if (!pendingPreds[matchId]) pendingPreds[matchId] = {};
  pendingPreds[matchId].aet_prediction = val;
  var s = document.getElementById('status-' + matchId);
  if (s) s.textContent = '· unsaved';
  updateSaveBtn();
}

function updateSaveBtn() {
  var btn = document.getElementById('save-preds-btn');
  if (!btn) return;
  var count = Object.keys(pendingPreds).length;
  if (count > 0) {
    btn.style.display = '';
    btn.textContent = '💾 Save (' + count + ')';
  } else {
    btn.style.display = 'none';
  }
}

async function savePredictions() {
  var btn = document.getElementById('save-preds-btn');
  var predictions = Object.entries(pendingPreds)
    .filter(function(e) { return e[1].prediction; })
    .map(function(e) {
      return { matchId: parseInt(e[0]), prediction: e[1].prediction, aet_prediction: e[1].aet_prediction || null };
    });
  if (!predictions.length) return;
  btn.disabled = true;
  btn.textContent = 'Saving…';
  try {
    var res = await fetch('/matches/predict-batch', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ predictions: predictions })
    });
    var data = await res.json();
    if (data.ok) {
      location.reload();
    } else {
      alert('Some picks couldn\'t be saved:\n' + (data.errors || []).join('\n'));
      btn.disabled = false;
      updateSaveBtn();
    }
  } catch(e) {
    alert('Network error — please try again.');
    btn.disabled = false;
    updateSaveBtn();
  }
}
</script>

<script>
// Auto-refresh when the next upcoming match changes (game completed)
(function() {
  var knownNextId = <%= nextMatch ? nextMatch.id : 'null' %>;
  if (!knownNextId) return;
  setInterval(function() {
    fetch('/api/next-match').then(function(r){ return r.json(); }).then(function(d) {
      if (d.id !== knownNextId) { location.replace('/dashboard'); }
    }).catch(function(){});
  }, 60000); // check every 60 seconds
})();
</script>

<script>
(function() {
  var KEY = 'chalet1267_welcome_v1';
  if (!localStorage.getItem(KEY)) {
    document.getElementById('welcome-overlay').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }
})();
function closeWelcome() {
  localStorage.setItem('chalet1267_welcome_v1', '1');
  document.getElementById('welcome-overlay').style.display = 'none';
  document.body.style.overflow = '';
}
</script>


<%- include('partials/header', { currentPage: 'dashboard' }) %>

<div class="page">
  <div class="container">

    <% if (flashSuccess) { %><div class="flash flash-success">✅ <%- flashSuccess %></div><% } %>
    <% if (flashError)   { %><div class="flash flash-error">⚠️ <%- flashError %></div><% } %>

    <!-- Greeting + rank/points only -->
    <div style="margin-bottom:20px">
      <h1 style="font-size:1.5rem;font-weight:800">
        👋 <span style="color:var(--gold)"><%= user.display_name %></span>
        <span style="font-size:.9rem;font-weight:500;color:var(--text-dim)">· Chalet 1267 – WC 2026</span>
      </h1>
      <% if (!user.is_admin) { %>
      <div style="display:flex;gap:14px;margin-top:14px;flex-wrap:wrap">
        <div class="stat-card" style="flex:1;min-width:130px">
          <div class="stat-value" style="color:var(--gold)">🏆 #<%= stats.rank %></div>
          <div class="stat-label">Current Rank<small style="color:var(--muted)"> / <%= stats.totalUsers %></small></div>
        </div>
        <div class="stat-card" style="flex:1;min-width:130px">
          <div class="stat-value"><%= stats.totalPts %></div>
          <div class="stat-label">Current Points</div>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Full leaderboard table -->
    <div class="section-header" style="margin-bottom:12px">
      <div>
        <div class="section-title">🏆 Leaderboard</div>
        <div class="section-subtitle">Live standings</div>
      </div>
      <a href="/leaderboard" class="btn btn-secondary btn-sm">Full Table →</a>
    </div>

    <div class="card" style="overflow:hidden;margin-bottom:28px;padding:0">
      <% if (displayMatch) { %>
      <div style="padding:8px 12px;background:rgba(255,255,255,.03);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:8px">
        <% if (prevNavMatch) { %>
          <a href="/dashboard?matchId=<%= prevNavMatch.id %>" class="btn btn-secondary btn-sm" style="padding:3px 10px;font-size:.78rem;flex-shrink:0">←</a>
        <% } else { %>
          <span style="width:36px;flex-shrink:0"></span>
        <% } %>
        <div style="text-align:center;font-size:.78rem;color:var(--text-dim);flex:1;display:flex;flex-direction:column;align-items:center;gap:2px">
          <div>
            <% if (displayMatch.has_result) { %><span style="font-size:.68rem;color:var(--muted);margin-right:4px">✅</span><% } %>
            <strong style="color:var(--text)"><%= displayMatch.team_a %> vs <%= displayMatch.team_b %></strong>
          </div>
          <% if (displayMatch.has_result) { %>
            <%
              const rLabel = displayMatch.match_result === 'draw'
                ? 'Draw'
                : 'Win (' + (displayMatch.match_result === 'team_a' ? displayMatch.team_a : displayMatch.team_b) + ')';
            %>
            <span style="color:var(--muted);font-size:.68rem">Result: <%= rLabel %></span>
          <% } else { %>
            <span style="color:var(--muted);font-size:.7rem">⏰ <%= displayMatch.match_time_kwt %></span>
          <% } %>
        </div>
        <% if (nextNavMatch) { %>
          <a href="/dashboard?matchId=<%= nextNavMatch.id %>" class="btn btn-secondary btn-sm" style="padding:3px 10px;font-size:.78rem;flex-shrink:0">→</a>
        <% } else { %>
          <span style="width:36px;flex-shrink:0"></span>
        <% } %>
      </div>
      <% } %>
      <table style="width:100%;border-collapse:collapse;font-size:.88rem">
        <thead>
          <tr style="background:rgba(255,255,255,.04);color:var(--text-dim);font-size:.72rem;text-transform:uppercase;letter-spacing:.04em">
            <th style="padding:9px 12px;text-align:left">#</th>
            <th style="padding:9px 12px;text-align:left">Player</th>
            <th style="padding:9px 12px;text-align:center">Next Pick</th>
            <th style="padding:9px 12px;text-align:right">Pts</th>
          </tr>
        </thead>
        <tbody>
          <% leaderboard.forEach((row, i) => { %>
          <%
            const isMe = row.id === user.id;
            const medal = row.rank === 1 ? '🥇' : row.rank === 2 ? '🥈' : row.rank === 3 ? '🥉' : '#' + row.rank;
            const nextPred = displayMatch ? nextPredMap[row.id] : null;
            let nextPredLabel = '—', nextPredColor = 'var(--muted)';
            if (nextPred && displayMatch) {
              if (nextPred === 'draw') { nextPredLabel = '🤝 Draw'; nextPredColor = 'var(--text)'; }
              else if (nextPred === 'team_a') { nextPredLabel = displayMatch.team_a; nextPredColor = 'var(--text)'; }
              else { nextPredLabel = displayMatch.team_b; nextPredColor = 'var(--text)'; }
            }
            // Show own pick always; show others' picks only when admin has enabled visibility for that round
            const showNextPick = nextPred && (isMe || nextMatchRoundVisible);
          %>
          <tr style="border-top:1px solid var(--border);<%= isMe ? 'background:rgba(59,130,246,.14);' : (i%2===0?'':'background:rgba(255,255,255,.015);') %>">
            <td style="padding:10px 12px;font-weight:700;color:<%= row.rank<=3 ? 'var(--gold)' : 'var(--text-dim)' %>"><%= medal %></td>
            <td style="padding:10px 12px;font-weight:<%= isMe ? '700' : '500' %>;color:<%= isMe ? 'var(--gold)' : 'var(--text)' %>">
              <% if (!isMe) { %>
                <a href="/users/<%= row.id %>/predictions" style="color:inherit;text-decoration:none;border-bottom:1px dotted rgba(255,255,255,.25)">
                  <%= row.display_name %>
                </a>
              <% } else { %>
                <%= row.display_name %>&nbsp;<span style="font-size:.68rem;color:var(--accent)">you</span>
              <% } %>
            </td>
            <td style="padding:10px 12px;text-align:center;font-size:.82rem">
              <% if (showNextPick) { %>
                <span style="color:<%= nextPredColor %>;font-weight:600"><%= nextPredLabel %></span>
              <% } else if (nextMatch && !nextPred) { %>
                <span style="color:var(--muted);font-size:.72rem">No pick</span>
              <% } else { %>
                <span style="color:var(--muted)">—</span>
              <% } %>
            </td>
            <td style="padding:10px 12px;text-align:right;font-weight:700;color:<%= isMe ? 'var(--gold)' : 'var(--text)' %>"><%= row.total %></td>
          </tr>
          <% }) %>
          <% if (leaderboard.length === 0) { %>
          <tr><td colspan="4" style="padding:20px;text-align:center;color:var(--text-dim)">No players yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Upcoming predictions + Recent results -->
    <div style="display:grid;gap:24px;grid-template-columns:1fr 1fr;" class="dashboard-cols">

      <div>
        <% if (user.is_admin && missingPreds) { %>
        <!-- Admin: Missing Predictions Table -->
        <div class="section-header" style="margin-bottom:12px">
          <div>
            <div class="section-title">📋 Missing Predictions</div>
            <div class="section-subtitle">By stage per player</div>
          </div>
        </div>
        <div class="card" style="padding:0;overflow:hidden">
          <div style="overflow-x:auto">
            <table style="width:100%;border-collapse:collapse;font-size:.8rem;min-width:340px">
              <thead>
                <tr style="background:rgba(255,255,255,.04);color:var(--text-dim);font-size:.68rem;text-transform:uppercase;letter-spacing:.04em">
                  <th style="padding:8px 10px;text-align:left">Player</th>
                  <th style="padding:8px 6px;text-align:center">Group</th>
                  <th style="padding:8px 6px;text-align:center">R32</th>
                  <th style="padding:8px 6px;text-align:center">R16</th>
                  <th style="padding:8px 6px;text-align:center">QF</th>
                  <th style="padding:8px 6px;text-align:center">SF</th>
                  <th style="padding:8px 6px;text-align:center">Final</th>
                </tr>
              </thead>
              <tbody>
                <% missingPreds.forEach((u, i) => { %>
                <tr style="border-top:1px solid var(--border);<%= i%2===0?'':'background:rgba(255,255,255,.015);' %>">
                  <td style="padding:9px 10px;font-weight:600;color:var(--text)"><%= u.display_name %></td>
                  <% ['group','r32','r16','qf','sf','final'].forEach(function(s) { %>
                  <%
                    const st = u.stages[s];
                    let cell, color;
                    if (st.done >= st.total && st.total > 0) { cell = '✓'; color = 'var(--green)'; }
                    else { cell = '—'; color = 'var(--muted)'; }
                  %>
                  <td style="padding:9px 6px;text-align:center;font-size:.75rem;font-weight:600;color:<%= color %>"><%= cell %></td>
                  <% }) %>
                </tr>
                <% }) %>
                <% if (missingPreds.length === 0) { %>
                <tr><td colspan="7" style="padding:20px;text-align:center;color:var(--text-dim)">No players yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <% } else { %>
        <!-- User: Predict Now -->
        <div class="section-header">
          <div>
            <div class="section-title">⏳ Predict Now</div>
            <div class="section-subtitle">Open matches</div>
          </div>
          <button id="save-preds-btn" onclick="savePredictions()" class="btn btn-primary btn-sm" style="display:none">💾 Save</button>
        </div>

        <% if (upcoming.length === 0) { %>
          <div class="card text-center text-muted" style="padding:28px">🔒 No open predictions right now.</div>
        <% } else { %>
          <div class="matches-grid">
            <% upcoming.forEach(m => { %>
            <div class="match-card<%= !m.prediction ? ' needs-pick' : '' %>" id="card-<%= m.id %>">
              <div class="match-header">
                <span><%= m.group_name ? `Group ${m.group_name}` : m.round.toUpperCase() %></span>
                <span>⏰ <%= m.match_time_kwt %></span>
              </div>
              <div class="match-body" style="padding:10px 14px">
                <div class="match-teams" style="margin-bottom:10px">
                  <div class="team-name team-a"><%= m.team_a %></div>
                  <div class="vs-badge">vs</div>
                  <div class="team-name team-b"><%= m.team_b %></div>
                </div>
                <% if (!m.is_knockout) { %>
                <div style="display:flex;gap:4px">
                  <button type="button" data-match="<%= m.id %>" data-val="team_a"
                    onclick="selectPred(<%= m.id %>,'team_a',this)"
                    class="dash-pred-btn<%= m.prediction==='team_a' ? ' dpb-sel' : '' %>"><%= m.team_a.split(' ')[0] %></button>
                  <button type="button" data-match="<%= m.id %>" data-val="draw"
                    onclick="selectPred(<%= m.id %>,'draw',this)"
                    class="dash-pred-btn<%= m.prediction==='draw' ? ' dpb-sel' : '' %>">🤝</button>
                  <button type="button" data-match="<%= m.id %>" data-val="team_b"
                    onclick="selectPred(<%= m.id %>,'team_b',this)"
                    class="dash-pred-btn<%= m.prediction==='team_b' ? ' dpb-sel' : '' %>"><%= m.team_b.split(' ')[0] %></button>
                </div>
                <div id="status-<%= m.id %>" style="text-align:center;font-size:.68rem;margin-top:4px;color:<%= m.prediction ? 'var(--muted)' : '#fbbf24' %>">
                  <%= m.prediction ? '✓ Saved' : '⚠ No pick yet' %>
                </div>
                <% } else { %>
                <div style="display:flex;gap:4px;margin-bottom:8px">
                  <button type="button" data-match="<%= m.id %>" data-val="team_a"
                    onclick="selectPred(<%= m.id %>,'team_a',this)"
                    class="dash-pred-btn<%= m.prediction==='team_a' ? ' dpb-sel' : '' %>" style="flex:1"><%= m.team_a.split(' ')[0] %></button>
                  <button type="button" data-match="<%= m.id %>" data-val="team_b"
                    onclick="selectPred(<%= m.id %>,'team_b',this)"
                    class="dash-pred-btn<%= m.prediction==='team_b' ? ' dpb-sel' : '' %>" style="flex:1"><%= m.team_b.split(' ')[0] %></button>
                </div>
                <div style="display:flex;gap:16px;justify-content:center;font-size:.75rem;color:var(--text-dim)">
                  <label style="display:flex;align-items:center;gap:4px;cursor:pointer">
                    <input type="radio" name="aet_<%= m.id %>" value="90min"
                      onchange="selectAET(<%= m.id %>,'90min')"
                      <%= m.aet_prediction==='90min' ? 'checked' : '' %>> ⏱️ 90 min
                  </label>
                  <label style="display:flex;align-items:center;gap:4px;cursor:pointer">
                    <input type="radio" name="aet_<%= m.id %>" value="aet"
                      onchange="selectAET(<%= m.id %>,'aet')"
                      <%= m.aet_prediction==='aet' ? 'checked' : '' %>> 🥅 AET
                  </label>
                </div>
                <div id="status-<%= m.id %>" style="text-align:center;font-size:.68rem;margin-top:4px;color:<%= m.prediction ? 'var(--muted)' : '#fbbf24' %>">
                  <%= m.prediction ? '✓ Saved' : '⚠ No pick yet' %>
                </div>
                <% } %>
              </div>
            </div>
            <% }) %>
          </div>
        <% } %>
        <% } %>
      </div>

      <div>
        <div class="section-header">
          <div>
            <div class="section-title">📊 Recent Results</div>
            <div class="section-subtitle">Your latest points</div>
          </div>
          <a href="/matches?round=group" class="btn btn-secondary btn-sm">All →</a>
        </div>

        <% if (recent.length === 0) { %>
          <div class="card text-center text-muted" style="padding:28px">No results yet.</div>
        <% } else { %>
          <div class="matches-grid">
            <% recent.forEach(m => { %>
            <%
              let cardClass = '';
              if (m.prediction && m.result) {
                cardClass = m.pts.main > 0 ? (m.pts.bonus > 0 ? 'bonus' : 'correct') : 'incorrect';
              }
            %>
            <div class="match-card <%= cardClass %>">
              <div class="match-header">
                <span><%= m.group_name ? `Group ${m.group_name}` : m.round.toUpperCase() %></span>
                <span class="<%= m.pts && m.pts.main > 0 ? 'text-green' : (m.prediction ? 'text-red' : 'text-muted') %>">
                  <% if (m.prediction && m.result) { %>+<%= (m.pts.main + m.pts.bonus) %> pts<% } else { %>No pred<% } %>
                </span>
              </div>
              <div class="match-body" style="padding:10px 16px">
                <div class="match-teams">
                  <div class="team-name team-a" style="font-size:.82rem"><%= m.team_a %></div>
                  <div style="text-align:center;flex-shrink:0">
                    <% if (m.score_a !== null && m.score_b !== null) { %>
                      <div style="font-size:1rem;font-weight:800;color:var(--text);letter-spacing:.05em"><%= m.score_a %> – <%= m.score_b %></div>
                    <% } else { %>
                      <div class="result-badge"><%= m.result === 'draw' ? '🤝' : '🏆' %></div>
                    <% } %>
                  </div>
                  <div class="team-name team-b" style="font-size:.82rem"><%= m.team_b %></div>
                </div>
                <% if (m.prediction) { %>
                <div class="match-actions">
                  <% if (m.pts.main > 0) { %>
                    <span class="prediction-pill correct">✅ Correct</span>
                    <% if (m.pts.bonus > 0) { %><span class="prediction-pill saved">⭐ Bonus</span><% } %>
                  <% } else { %>
                    <span class="prediction-pill incorrect">❌ Wrong</span>
                  <% } %>
                </div>
                <% } %>
              </div>
            </div>
            <% }) %>
          </div>
        <% } %>
      </div>

    </div>

    <% if (user.is_admin && lockStatus) { %>
    <!-- Admin: Lock / Unlock Predictions -->
    <div style="margin-top:28px">
      <div class="section-header" style="margin-bottom:12px">
        <div>
          <div class="section-title">🔒 Lock / Unlock Predictions</div>
          <div class="section-subtitle">Control prediction access per round</div>
        </div>
        <form method="POST" action="/admin/sync-scores" onsubmit="this.querySelector('button').textContent='Syncing…';this.querySelector('button').disabled=true">
          <button type="submit" class="btn btn-sm" style="background:#059669;border-color:#059669;color:#fff">🔄 Sync ESPN</button>
        </form>
      </div>
      <div class="card" style="padding:0;overflow:hidden">
        <div style="overflow-x:auto">
          <table style="width:100%;border-collapse:collapse;font-size:.8rem;min-width:400px">
            <thead>
              <tr style="background:rgba(255,255,255,.04);color:var(--text-dim);font-size:.68rem;text-transform:uppercase;letter-spacing:.04em">
                <th style="padding:8px 10px;text-align:left">Round</th>
                <th style="padding:8px 8px;text-align:center">Prediction Status</th>
                <th style="padding:8px 8px;text-align:center">Picks Visible</th>
              </tr>
            </thead>
            <tbody>
              <%
                const adminRounds = [
                  { key: 'group_md1', label: 'Group MD1', dot: '#ef4444' },
                  { key: 'group_md2', label: 'Group MD2', dot: '#3b82f6' },
                  { key: 'group_md3', label: 'Group MD3', dot: '#22c55e' },
                  { key: 'r32',   label: 'R32'   },
                  { key: 'r16',   label: 'R16'   },
                  { key: 'qf',    label: 'QF'    },
                  { key: 'sf',    label: 'SF'    },
                  { key: '3rd',   label: '3rd Place' },
                  { key: 'final', label: 'Final' },
                ];
              %>
              <% adminRounds.forEach((r, i) => {
                const ls = lockStatus[r.key] || { total: 0, locked: 0 };
                const allLocked = ls.total > 0 && ls.locked === ls.total;
                const noneLocked = ls.locked === 0;
                const isVisible = visibilityStatus[r.key] === 1;
              %>
              <tr style="border-top:1px solid var(--border);<%= i%2===1?'background:rgba(255,255,255,.015)':'' %>">
                <td style="padding:9px 10px;font-weight:600;color:var(--text)">
                  <div style="display:flex;align-items:center;gap:6px">
                    <% if (r.dot) { %><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:<%= r.dot %>"></span><% } else { %><span style="font-size:.8rem">🏆</span><% } %>
                    <%= r.label %>
                  </div>
                </td>
                <td style="padding:9px 8px;text-align:center">
                  <% if (ls.total === 0) { %>
                    <span style="font-size:.75rem;color:var(--muted)">—</span>
                  <% } else { %>
                  <form method="POST" action="/admin/matches/lock-round" style="display:inline-flex;align-items:center;gap:6px">
                    <input type="hidden" name="round" value="<%= r.key %>">
                    <% if (allLocked) { %>
                      <span style="font-size:.75rem;color:#f87171;font-weight:600">🔒 Locked</span>
                      <button type="submit" name="action" value="unlock" class="btn btn-sm" style="background:rgba(34,197,94,.15);color:#4ade80;border-color:#4ade80;font-size:.68rem;padding:2px 8px">Unlock</button>
                    <% } else if (noneLocked) { %>
                      <span style="font-size:.75rem;color:var(--green);font-weight:600">🔓 Open</span>
                      <button type="submit" name="action" value="lock" class="btn btn-sm" style="background:rgba(239,68,68,.15);color:#f87171;border-color:#f87171;font-size:.68rem;padding:2px 8px">Lock</button>
                    <% } else { %>
                      <span style="font-size:.75rem;color:var(--gold)"><%= ls.locked %>/<%= ls.total %> locked</span>
                      <button type="submit" name="action" value="lock" class="btn btn-sm" style="background:rgba(239,68,68,.15);color:#f87171;border-color:#f87171;font-size:.68rem;padding:2px 8px">Lock All</button>
                      <button type="submit" name="action" value="unlock" class="btn btn-sm" style="background:rgba(34,197,94,.15);color:#4ade80;border-color:#4ade80;font-size:.68rem;padding:2px 8px">Unlock</button>
                    <% } %>
                  </form>
                  <% } %>
                </td>
                <td style="padding:9px 8px;text-align:center">
                  <form method="POST" action="/admin/rounds/<%= r.key %>/visibility" style="display:inline-flex;align-items:center;gap:4px">
                    <% if (isVisible) { %>
                      <span style="font-size:.72rem;color:var(--green)">👁 On</span>
                      <button type="submit" name="action" value="hide" class="btn btn-sm" style="background:rgba(239,68,68,.15);color:#f87171;border-color:#f87171;font-size:.68rem;padding:2px 7px">Hide</button>
                    <% } else { %>
                      <span style="font-size:.72rem;color:var(--muted)">🙈 Off</span>
                      <button type="submit" name="action" value="show" class="btn btn-sm" style="background:rgba(34,197,94,.15);color:#4ade80;border-color:#4ade80;font-size:.68rem;padding:2px 7px">Show</button>
                    <% } %>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>

    <div class="mt-24">
      <a href="/rules" class="btn btn-secondary">📋 Rules</a>
    </div>

  </div>
</div>

<!-- ── One-time Welcome Popup ──────────────────────────────────────────────── -->
<div id="welcome-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:1000;overflow-y:auto;padding:20px 12px">
  <div style="max-width:520px;margin:auto;background:var(--surface);border-radius:16px;border:1px solid var(--border);padding:28px 24px">
    <div style="text-align:center;margin-bottom:20px">
      <div style="font-size:2.4rem">⚽</div>
      <h2 style="font-size:1.4rem;font-weight:800;color:var(--gold);margin:8px 0 4px">Welcome to Chalet 1267!</h2>
      <p style="color:var(--text-dim);font-size:.88rem">World Cup 2026 Prediction Competition</p>
    </div>

    <div style="margin-bottom:16px">
      <h3 style="font-size:.95rem;font-weight:700;margin-bottom:8px;color:var(--text)">📋 How to Predict</h3>
      <p style="font-size:.86rem;color:var(--text-dim);line-height:1.65">
        Open <strong style="color:var(--text)">Matches</strong> and tap <strong style="color:var(--accent)">⚽ Predict</strong> on any match card.
        For <strong style="color:var(--text)">Group Stage</strong>: pick <em>Team A wins · Draw · Team B wins</em>.
        For <strong style="color:var(--text)">Knockout</strong>: pick <em>who wins</em> + <em>90 min or AET</em>.
        You can edit your pick any time before kick-off. After kick-off it's 🔒 locked.
      </p>
    </div>

    <div style="margin-bottom:20px">
      <h3 style="font-size:.95rem;font-weight:700;margin-bottom:10px;color:var(--text)">🏅 Scoring</h3>
      <table style="width:100%;border-collapse:collapse;font-size:.82rem">
        <thead>
          <tr style="background:rgba(255,255,255,.05);color:var(--text-dim)">
            <th style="padding:6px 10px;text-align:left">Stage</th>
            <th style="padding:6px 10px;text-align:right">Points</th>
            <th style="padding:6px 10px;text-align:right;color:var(--gold)">+ AET Bonus</th>
          </tr>
        </thead>
        <tbody>

<%- include('partials/header', { currentPage: 'matches' }) %>

<style>
/* ── Inline prediction form ─────────────────────────────────────────────────── */
.predict-form {
  border-top: 1px solid var(--border);
  padding: 12px 16px 14px;
  background: rgba(0,0,0,.18);
  border-radius: 0 0 12px 12px;
}
.predict-opts {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.predict-opt input[type="radio"] { display: none; }
.predict-opt label {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 8px 6px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  font-size: .82rem;
  font-weight: 600;
  color: var(--text-dim);
  transition: all .15s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}
.predict-opt input[type="radio"]:checked + label {
  border-color: var(--accent);
  background: rgba(59,130,246,.15);
  color: var(--text);
}
.predict-opt label:hover { border-color: var(--accent); color: var(--text); }
.predict-aet {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  font-size: .8rem;
  color: var(--text-dim);
}
.predict-aet input[type="radio"] { display: none; }
.predict-aet label {
  padding: 5px 14px;
  border: 1.5px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  font-size: .8rem;
  color: var(--text-dim);
  transition: all .15s;
}
.predict-aet input[type="radio"]:checked + label {
  border-color: var(--gold);
  background: rgba(251,191,36,.12);
  color: var(--gold);
}
.predict-aet label:hover { border-color: var(--gold); }
.saved-pred-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
/* ── Sticky save bar ────────────────────────────────────────────────────────── */
#save-bar {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--surface);
  border-bottom: 2px solid var(--accent);
  padding: 10px 16px;
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,.4);
}
#save-bar-info { font-size: .85rem; color: var(--text-dim); }
#save-bar-info strong { color: var(--accent); }
</style>

<!-- Sticky batch save bar (hidden until pending predictions exist) -->
<div id="save-bar">
  <div id="save-bar-info">⚽ <strong id="save-bar-count">0</strong> unsaved prediction(s)</div>
  <button id="save-bar-btn" onclick="saveAll()" class="btn btn-primary" style="padding:8px 20px">
    💾 Save All
  </button>
</div>

<div class="page">
  <div class="container">

    <% if (flashSuccess) { %><div class="flash flash-success">✅ <%- flashSuccess %></div><% } %>
    <% if (flashError)   { %><div class="flash flash-error">⚠️ <%- flashError %></div><% } %>

    <div class="section-header">
      <div>
        <div class="section-title">⚽ Match Predictions</div>
        <div class="section-subtitle"><%= matches.length %> matches · All times in Kuwait Time (KWT)</div>
      </div>
    </div>

    <!-- Round filters -->
    <div class="tabs mb-16">
      <a href="/matches"              class="tab-btn <%= !filter.round && !filter.group ? 'active' : '' %>">All</a>
      <a href="/matches?round=group"  class="tab-btn <%= filter.round === 'group' ? 'active' : '' %>">Groups</a>
      <a href="/matches?round=r32"    class="tab-btn <%= filter.round === 'r32'   ? 'active' : '' %>">R32</a>
      <a href="/matches?round=r16"    class="tab-btn <%= filter.round === 'r16'   ? 'active' : '' %>">R16</a>
      <a href="/matches?round=qf"     class="tab-btn <%= filter.round === 'qf'    ? 'active' : '' %>">QF</a>
      <a href="/matches?round=sf"     class="tab-btn <%= filter.round === 'sf'    ? 'active' : '' %>">SF</a>
      <a href="/matches?round=final"  class="tab-btn <%= filter.round === 'final' ? 'active' : '' %>">Final</a>
    </div>

    <!-- Group sub-filter -->
    <% if (!filter.round || filter.round === 'group') { %>
    <div class="lb-filters mb-16">
      <a href="/matches?round=group" class="lb-filter-btn <%= filter.round === 'group' && !filter.group ? 'active' : '' %>">All Groups</a>
      <% groups.forEach(g => { %>
        <a href="/matches?group=<%= g %>" class="lb-filter-btn <%= filter.group === g ? 'active' : '' %>">Group <%= g %></a>
      <% }) %>
    </div>
    <% } %>

    <% if (matches.length === 0) { %>
      <div class="card text-center" style="padding:40px">
        <div style="font-size:2rem;margin-bottom:12px">🔍</div>
        <p class="text-muted">No matches found for this filter.</p>
      </div>
    <% } else { %>

    <div class="matches-grid">
      <% matches.forEach(m => { %>
      <%
        let cardClass = '';
        if (m.prediction && m.result) {
          cardClass = m.pts.main > 0 ? (m.pts.bonus > 0 ? 'bonus' : 'correct') : 'incorrect';
        } else if (m.is_locked) {
          cardClass = 'locked';
        }
      %>
      <div class="match-card <%= cardClass %>" id="card-<%= m.id %>">
        <div class="match-header">
          <div style="display:flex;align-items:center;gap:6px">
            <% if (m.group_name) { %>
              <%
                const mdNum = m.match_num <= 24 ? 1 : m.match_num <= 48 ? 2 : 3;
                const mdColor = mdNum === 1 ? '#ef4444' : mdNum === 2 ? '#3b82f6' : '#22c55e';
              %>
              <span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:<%= mdColor %>;font-size:.6rem;font-weight:800;color:#fff;flex-shrink:0" title="Matchday <%= mdNum %>">M<%= mdNum %></span>
              <span class="match-round-badge group">Group <%= m.group_name %></span>
            <% } else { %>
              <span class="match-round-badge knockout"><%= m.round.toUpperCase() %></span>
            <% } %>
            <span style="color:var(--text-dim);font-size:.75rem"><%= m.stadium %></span>
          </div>
          <span style="font-size:.75rem;color:var(--text-dim)">⏰ <%= m.match_time_kwt %></span>
        </div>

        <div class="match-body">
          <div class="match-teams">
            <div class="team-name team-a">
              <% if (m.result === 'team_a') { %>🏆 <% } %>
              <%= m.team_a %>
            </div>
            <% if (m.result) { %>
              <div class="result-badge">
                <% if (m.result === 'draw') { %>🤝<% } else { %><%= m.result === 'team_a' ? m.team_a.split(' ')[0] : m.team_b.split(' ')[0] %><% } %>
                <% if (m.aet_result === 'aet') { %><div style="font-size:.62rem;margin-top:2px;color:var(--text-dim)">AET</div><% } %>
              </div>
            <% } else { %>
              <div class="vs-badge">vs</div>
            <% } %>
            <div class="team-name team-b">
              <% if (m.result === 'team_b') { %>🏆 <% } %>
              <%= m.team_b %>
            </div>
          </div>

          <div class="match-actions">
            <% if (m.result) { %>
              <%/* ── Result is in ── */%>
              <% if (m.prediction) { %>
                <% if (m.pts.main > 0) { %>
                  <span class="prediction-pill correct">✅ +<%= m.pts.main + m.pts.bonus %> pts</span>
                  <% if (m.pts.bonus > 0) { %><span class="prediction-pill saved" style="font-size:.7rem">⭐ Bonus +1</span><% } %>
                <% } else { %>
                  <span class="prediction-pill incorrect">❌ Wrong</span>
                <% } %>
              <% } else { %>
                <span class="prediction-pill locked">No prediction</span>
              <% } %>

            <% } else if (m.is_locked) { %>
              <%/* ── Locked, no result yet ── */%>
              <span class="prediction-pill locked">🔒 Locked</span>
              <% if (m.prediction) { %>
                <span class="prediction-pill saved" style="font-size:.75rem">
                  <%= m.prediction === 'team_a' ? m.team_a : (m.prediction === 'draw' ? '🤝 Draw' : m.team_b) %>
                  <% if (m.aet_prediction) { %> · <%= m.aet_prediction === '90min' ? '90min' : 'AET' %><% } %>
                </span>
              <% } %>

            <% } else { %>
              <%/* ── Open for prediction ── */%>
              <div class="saved-pred-row">
                <% if (m.prediction) { %>
                  <span class="prediction-pill saved" id="pill-<%= m.id %>">
                    <%= m.prediction === 'team_a' ? m.team_a : (m.prediction === 'draw' ? '🤝 Draw' : m.team_b) %>
                    <% if (m.aet_prediction) { %> · <%= m.aet_prediction === '90min' ? '90min' : 'AET' %><% } %>
                  </span>
                  <% if (!user.is_admin) { %>
                  <button class="btn btn-secondary btn-sm" onclick="togglePredictForm('<%= m.id %>')">✏️ Edit</button>
                  <% } %>
                <% } else { %>
                  <% if (!user.is_admin) { %>
                  <button class="btn btn-primary btn-sm" onclick="togglePredictForm('<%= m.id %>')">⚽ Predict</button>
                  <% } %>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>

        <%/* ── Inline prediction form (only for open non-admin) ── */%>
        <% if (!m.result && !m.is_locked && !user.is_admin) { %>
        <div id="predict-form-<%= m.id %>" class="predict-form" style="display:none">

          <div class="predict-opts">
            <div class="predict-opt">
              <input type="radio" id="pa_<%= m.id %>" name="pred_<%= m.id %>" value="team_a"
                     <%= m.prediction === 'team_a' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, <%= m.is_knockout ? 'true' : 'false' %>)">
              <label for="pa_<%= m.id %>" title="<%= m.team_a %>"><%= m.team_a %></label>
            </div>
            <% if (!m.is_knockout) { %>
            <div class="predict-opt">
              <input type="radio" id="pd_<%= m.id %>" name="pred_<%= m.id %>" value="draw"
                     <%= m.prediction === 'draw' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, false)">
              <label for="pd_<%= m.id %>">🤝 Draw</label>
            </div>
            <% } %>
            <div class="predict-opt">
              <input type="radio" id="pb_<%= m.id %>" name="pred_<%= m.id %>" value="team_b"
                     <%= m.prediction === 'team_b' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, <%= m.is_knockout ? 'true' : 'false' %>)">
              <label for="pb_<%= m.id %>" title="<%= m.team_b %>"><%= m.team_b %></label>
            </div>
          </div>

          <% if (m.is_knockout) { %>
          <div class="predict-aet">
            <span>Decided in:</span>
            <div>
              <input type="radio" id="a90_<%= m.id %>" name="aet_<%= m.id %>" value="90min"
                     <%= m.aet_prediction === '90min' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, true)">
              <label for="a90_<%= m.id %>">90 min</label>
            </div>
            <div>
              <input type="radio" id="aet_<%= m.id %>" name="aet_<%= m.id %>" value="aet"
                     <%= m.aet_prediction === 'aet' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, true)">
              <label for="aet_<%= m.id %>">AET / Pens</label>
            </div>
          </div>
          <% } %>

          <div style="font-size:.75rem;color:var(--text-dim);margin-top:6px;text-align:center">
            Selections auto-tracked · hit <strong style="color:var(--accent)">Save All</strong> at the top when ready
          </div>

        </div>
        <% } %>

      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<!-- Seed saved predictions from server for change-detection -->
<script>
const savedPredictions = {
  <% matches.forEach(m => { if (m.prediction) { %>
  <%= m.id %>: { prediction: '<%= m.prediction %>', aet_prediction: <%= m.aet_prediction ? `'${m.aet_prediction}'` : 'null' %> },
  <% } }) %>
};

const pending = {};

function setPending(matchId, isKnockout) {
  const predEl = document.querySelector(`input[name="pred_${matchId}"]:checked`);
  if (!predEl) return;
  const pred = predEl.value;
  let aet = null;
  if (isKnockout) {
    const aetEl = document.querySelector(`input[name="aet_${matchId}"]:checked`);
    aet = aetEl ? aetEl.value : null;
  }
  const saved = savedPredictions[matchId];
  const unchanged = saved && saved.prediction === pred && saved.aet_prediction === aet;
  if (unchanged) {
    delete pending[matchId];
  } else {
    pending[matchId] = { prediction: pred, aet_prediction: aet };
  }
  updateSaveBar();
}

function updateSaveBar() {
  const count = Object.keys(pending).length;
  const bar = document.getElementById('save-bar');
  const btn = document.getElementById('save-bar-btn');
  const countEl = document.getElementById('save-bar-count');
  countEl.textContent = count;
  bar.style.display = count > 0 ? 'flex' : 'none';
  if (btn) btn.textContent = `💾 Save All (${count})`;
}

async function saveAll() {
  const btn = document.getElementById('save-bar-btn');
  btn.disabled = true;
  btn.textContent = 'Saving…';

  const predictions = Object.entries(pending).map(([matchId, data]) => ({
    matchId: parseInt(matchId),
    prediction: data.prediction,
    aet_prediction: data.aet_prediction
  }));

  try {
    const resp = await fetch('/matches/predict-batch', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ predictions })
    });
    const data = await resp.json();
    if (data.ok) {
      window.location.reload();
    } else {
      const msg = data.errors && data.errors.length ? data.errors.join('\n') : 'Unknown error';
      alert('⚠️ Could not save some predictions:\n' + msg);
      btn.disabled = false;
      updateSaveBar();
    }
  } catch (e) {
    alert('Save failed — please try again.');
    btn.disabled = false;
    updateSaveBar();
  }
}

function togglePredictForm(id) {
  const form = document.getElementById('predict-form-' + id);
  if (!form) return;
  const isOpen = form.style.display !== 'none';
  document.querySelectorAll('.predict-form').forEach(f => f.style.display = 'none');
  if (!isOpen) {
    form.style.display = 'block';
    form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
}
</script>

<%- include('partials/footer') %>

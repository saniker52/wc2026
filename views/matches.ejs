<%- include('partials/header', { currentPage: 'matches' }) %>

<div class="page">
  <div class="container">

    <% if (flashSuccess) { %><div class="flash flash-success">✅ <%- flashSuccess %></div><% } %>
    <% if (flashError)   { %><div class="flash flash-error">⚠️ <%- flashError %></div><% } %>

    <div class="section-header">
      <div>
        <div class="section-title">⚽ Match Predictions</div>
        <div class="section-subtitle"><%= matches.length %> matches shown · All times in Kuwait Time</div>
      </div>
    </div>

    <!-- Filters -->
    <div class="tabs mb-16">
      <a href="/matches" class="tab-btn <%= !filter.round && !filter.group ? 'active' : '' %>">All Matches</a>
      <a href="/matches?round=group" class="tab-btn <%= filter.round === 'group' ? 'active' : '' %>">Group Stage</a>
      <a href="/matches?round=r32"   class="tab-btn <%= filter.round === 'r32'   ? 'active' : '' %>">Round of 32</a>
      <a href="/matches?round=r16"   class="tab-btn <%= filter.round === 'r16'   ? 'active' : '' %>">Round of 16</a>
      <a href="/matches?round=qf"    class="tab-btn <%= filter.round === 'qf'    ? 'active' : '' %>">Quarterfinals</a>
      <a href="/matches?round=sf"    class="tab-btn <%= filter.round === 'sf'    ? 'active' : '' %>">Semifinals</a>
      <a href="/matches?round=final" class="tab-btn <%= filter.round === 'final' ? 'active' : '' %>">Final</a>
    </div>

    <!-- Group filter (shown in group view) -->
    <% if (!filter.round || filter.round === 'group') { %>
    <div class="lb-filters mb-16">
      <a href="/matches?round=group" class="lb-filter-btn <%= filter.round === 'group' && !filter.group ? 'active' : '' %>">All Groups</a>
      <% groups.forEach(g => { %>
        <a href="/matches?group=<%= g %>" class="lb-filter-btn <%= filter.group === g ? 'active' : '' %>">Group <%= g %></a>
      <% }) %>
    </div>
    <% } %>

    <% if (matches.length === 0) { %>
      <div class="card text-center" style="padding:40px">
        <div style="font-size:2rem;margin-bottom:12px">🔍</div>
        <p class="text-muted">No matches found for this filter.</p>
      </div>
    <% } else { %>
    <div class="matches-grid">
      <% matches.forEach(m => { %>
      <%
        let cardClass = '';
        if (m.prediction && m.result) {
          cardClass = m.pts.main > 0 ? (m.pts.bonus > 0 ? 'bonus' : 'correct') : 'incorrect';
        } else if (m.is_locked) {
          cardClass = 'locked';
        }
      %>
      <div class="match-card <%= cardClass %>">
        <div class="match-header">
          <div style="display:flex;align-items:center;gap:8px">
            <% if (m.group_name) { %>
              <span class="match-round-badge group">Group <%= m.group_name %></span>
            <% } else { %>
              <span class="match-round-badge knockout"><%= m.round.toUpperCase() %></span>
            <% } %>
            <span style="color:var(--text-dim);font-size:.78rem"><%= m.city %></span>
          </div>
          <span style="font-size:.78rem;color:var(--text-dim)">⏰ <%= m.match_time_kwt %></span>
        </div>

        <div class="match-body">
          <div class="match-teams">
            <div class="team-name team-a">
              <% if (m.result === 'team_a') { %>🏆 <% } %>
              <%= m.team_a %>
            </div>
            <% if (m.result) { %>
              <div class="result-badge">
                <%= m.result === 'draw' ? 'Draw' : (m.result === 'team_a' ? m.team_a.split(' ')[0] : m.team_b.split(' ')[0]) %>
                <% if (m.aet_result === 'aet') { %><div style="font-size:.65rem;margin-top:2px;color:var(--text-dim)">AET</div><% } %>
              </div>
            <% } else { %>
              <div class="vs-badge">vs</div>
            <% } %>
            <div class="team-name team-b">
              <% if (m.result === 'team_b') { %>🏆 <% } %>
              <%= m.team_b %>
            </div>
          </div>

          <div class="match-actions">
            <% if (m.result) { %>
              <!-- Result in -->
              <% if (m.prediction) { %>
                <% if (m.pts.main > 0) { %>
                  <span class="prediction-pill correct">✅ +<%= m.pts.main + m.pts.bonus %> pts</span>
                  <% if (m.pts.bonus > 0) { %><span class="prediction-pill saved" style="font-size:.7rem">⭐ Bonus +1</span><% } %>
                <% } else { %>
                  <span class="prediction-pill incorrect">❌ Wrong</span>
                <% } %>
              <% } else { %>
                <span class="prediction-pill locked">No prediction</span>
              <% } %>
            <% } else if (m.is_locked) { %>
              <span class="prediction-pill locked">🔒 Locked</span>
              <% if (m.prediction) { %>
                <span class="prediction-pill saved" style="font-size:.72rem">
                  <%= m.prediction === 'team_a' ? m.team_a : (m.prediction === 'draw' ? 'Draw' : m.team_b) %>
                </span>
              <% } %>
            <% } else { %>
              <% if (m.prediction) { %>
                <span class="prediction-pill saved">
                  <%= m.prediction === 'team_a' ? m.team_a : (m.prediction === 'draw' ? 'Draw' : m.team_b) %>
                </span>
                <a href="/matches/<%= m.id %>" class="btn btn-secondary btn-sm">Edit</a>
              <% } else { %>
                <a href="/matches/<%= m.id %>" class="btn btn-primary btn-sm">Predict →</a>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/header', { currentPage: 'matches' }) %>

<style>
/* ── Inline prediction form ─────────────────────────────────────────────────── */
.predict-form {
  border-top: 1px solid var(--border);
  padding: 12px 16px 14px;
  background: rgba(0,0,0,.18);
  border-radius: 0 0 12px 12px;
}
.predict-opts {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.predict-opt input[type="radio"] { display: none; }
.predict-opt label {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 8px 6px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  font-size: .82rem;
  font-weight: 600;
  color: var(--text-dim);
  transition: all .15s;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}
.predict-opt input[type="radio"]:checked + label {
  border-color: var(--accent);
  background: rgba(59,130,246,.15);
  color: var(--text);
}
.predict-opt label:hover { border-color: var(--accent); color: var(--text); }
.predict-aet {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  font-size: .8rem;
  color: var(--text-dim);
}
.predict-aet input[type="radio"] { display: none; }
.predict-aet label {
  padding: 5px 14px;
  border: 1.5px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  font-size: .8rem;
  color: var(--text-dim);
  transition: all .15s;
}
.predict-aet input[type="radio"]:checked + label {
  border-color: var(--gold);
  background: rgba(251,191,36,.12);
  color: var(--gold);
}
.predict-aet label:hover { border-color: var(--gold); }
.saved-pred-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
/* ── Sticky save bar ────────────────────────────────────────────────────────── */
#save-bar {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--surface);
  border-bottom: 2px solid var(--accent);
  padding: 10px 16px;
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  box-shadow: 0 2px 12px rgba(0,0,0,.4);
}
#save-bar-info { font-size: .85rem; color: var(--text-dim); }
#save-bar-info strong { color: var(--accent); }
/* ── Result badge redesign ──────────────────────────────────────────────────── */
.result-badge {
  min-width: 76px;
  text-align: center;
}
.result-score {
  font-size: 1.05rem;
  font-weight: 900;
  color: var(--text);
  letter-spacing: 1px;
  line-height: 1;
}
.result-outcome {
  font-size: .62rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-top: 3px;
}
.result-aet {
  font-size: .58rem;
  color: var(--text-dim);
  margin-top: 1px;
}
/* ── Match num badge ────────────────────────────────────────────────────────── */
.match-num-badge {
  font-size: .65rem;
  font-weight: 700;
  color: var(--muted);
  background: rgba(255,255,255,.05);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1px 5px;
  flex-shrink: 0;
}
</style>

<!-- Sticky batch save bar -->
<div id="save-bar">
  <div id="save-bar-info">⚽ <strong id="save-bar-count">0</strong> unsaved prediction(s)</div>
  <button id="save-bar-btn" onclick="saveAll()" class="btn btn-primary" style="padding:8px 20px">
    💾 Save All
  </button>
</div>

<div class="page">
  <div class="container">

    <% if (flashSuccess) { %><div class="flash flash-success">✅ <%- flashSuccess %></div><% } %>
    <% if (flashError)   { %><div class="flash flash-error">⚠️ <%- flashError %></div><% } %>

    <div class="section-header" style="margin-bottom:16px">
      <div>
        <div class="section-title">⚽ Match Predictions</div>
        <div class="section-subtitle"><%= matches.length %> matches · All times in Kuwait Time (KWT)</div>
      </div>
      <button onclick="scrollToRecent()" class="btn btn-secondary btn-sm">Go to Recent →</button>
    </div>

    <% if (matches.length === 0) { %>
      <div class="card text-center" style="padding:40px">
        <div style="font-size:2rem;margin-bottom:12px">🔍</div>
        <p class="text-muted">No matches found for this filter.</p>
      </div>
    <% } else { %>

    <!-- Centered single-column grid -->
    <div class="matches-grid" style="max-width:700px;margin:0 auto">
      <% matches.forEach(m => { %>
      <%
        let cardClass = '';
        if (m.prediction && m.result) {
          cardClass = m.pts.main > 0 ? (m.pts.bonus > 0 ? 'bonus' : 'correct') : 'incorrect';
        } else if (m.is_locked) {
          cardClass = 'locked';
        }
        // Stadium country flag based on city
        const cityFlag = m.city && m.city.includes('Mexico') ? '🇲🇽' : m.city && m.city.includes('Canada') ? '🇨🇦' : '🇺🇸';
      %>
      <div class="match-card <%= cardClass %>" id="card-<%= m.id %>" data-played="<%= m.result ? '1' : '0' %>">

        <!-- Card header: matchday dot + group badge + match# + stadium + time -->
        <div class="match-header">
          <div style="display:flex;align-items:center;gap:6px;min-width:0;flex:1">
            <% if (m.group_name) { %>
              <span style="font-size:.65rem;color:var(--muted)">Group <%= m.group_name %> · MD<%= m.matchday %></span>
            <% } else { %>
              <span style="font-size:.65rem;color:var(--muted)"><%= m.round.toUpperCase() %></span>
            <% } %>
            <span class="match-num-badge">#<%= m.officialNum %></span>
            <span style="color:var(--text-dim);font-size:.73rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= cityFlag %>&nbsp;<%= m.stadium %></span>
          </div>
          <span style="font-size:.73rem;color:var(--text-dim);white-space:nowrap;flex-shrink:0">⏰ <%= m.match_time_kwt %></span>
        </div>

        <!-- Card body: teams + result/vs + prediction actions -->
        <div class="match-body">
          <div class="match-teams">
            <%
              const aWon = m.result === 'team_a';
              const bWon = m.result === 'team_b';
              const isDraw = m.result === 'draw';
            %>
            <div class="team-name team-a" style="<%= m.result ? (aWon ? 'color:rgba(255,255,255,.8)' : 'color:rgba(255,255,255,.35)') : '' %>">
              <%= m.team_a %>
            </div>

            <% if (m.result) { %>
              <div class="result-badge" style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:6px 10px">
                <% if (m.score_a !== null && m.score_a !== undefined) { %>
                  <div class="result-score"><%= m.score_a %> – <%= m.score_b %></div>
                <% } %>
                <% if (m.aet_result === 'aet') { %>
                  <div class="result-aet">AET</div>
                <% } %>
              </div>
            <% } else { %>
              <div class="vs-badge">vs</div>
            <% } %>

            <div class="team-name team-b" style="<%= m.result ? (bWon ? 'color:rgba(255,255,255,.8)' : 'color:rgba(255,255,255,.35)') : '' %>">
              <%= m.team_b %>
            </div>
          </div>

          <!-- Prediction status / actions -->
          <div class="match-actions">
            <% if (m.result) { %>
              <%/* ── Result is in ── */%>
              <% if (m.prediction) { %>
                <% if (m.pts.main > 0) { %>
                  <span class="prediction-pill correct">✅ +<%= m.pts.main + m.pts.bonus %> pts</span>
                  <% if (m.pts.bonus > 0) { %><span class="prediction-pill saved" style="font-size:.7rem">⭐ AET +1</span><% } %>
                <% } else { %>
                  <span class="prediction-pill incorrect">❌ Wrong</span>
                <% } %>
                <span style="font-size:.7rem;color:var(--muted)">
                  Prediction: <%= m.prediction === 'team_a' ? m.team_a.split(' ')[0] : (m.prediction === 'draw' ? '🤝' : m.team_b.split(' ')[0]) %>
                </span>
              <% } %>
              <% if (m.tally) { %>
                <span style="font-size:.7rem;color:var(--muted)">All picks: <%= m.tally.correct %>/<%= m.tally.total %> ✓</span>
              <% } %>

            <% } else if (m.is_locked) { %>
              <%/* ── Locked, no result yet ── */%>
              <% if (user.is_admin) { %><span class="prediction-pill locked">🔒 Locked</span><% } %>
              <% if (m.prediction) { %>
                <span class="prediction-pill saved" style="font-size:.75rem">
                  <%= m.prediction === 'team_a' ? m.team_a.split(' ')[0] : (m.prediction === 'draw' ? '🤝 Draw' : m.team_b.split(' ')[0]) %>
                  <% if (m.aet_prediction) { %> · <%= m.aet_prediction === '90min' ? '90m' : 'AET' %><% } %>
                </span>
              <% } %>

            <% } else { %>
              <%/* ── Open for prediction ── */%>
              <div class="saved-pred-row">
                <% if (m.prediction) { %>
                  <span class="prediction-pill saved" id="pill-<%= m.id %>">
                    <%= m.prediction === 'team_a' ? m.team_a.split(' ')[0] : (m.prediction === 'draw' ? '🤝 Draw' : m.team_b.split(' ')[0]) %>
                    <% if (m.aet_prediction) { %> · <%= m.aet_prediction === '90min' ? '90m' : 'AET' %><% } %>
                  </span>
                  <% if (!user.is_admin) { %>
                  <button class="btn btn-secondary btn-sm" onclick="togglePredictForm('<%= m.id %>')">✏️ Edit</button>
                  <% } %>
                <% } else { %>
                  <% if (!user.is_admin) { %>
                  <button class="btn btn-primary btn-sm" onclick="togglePredictForm('<%= m.id %>')">⚽ Predict</button>
                  <% } %>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>

        <%/* ── View all picks button ── */%>
        <% if (m.result || user.is_admin || m.picksVisible) { %>
        <div style="padding:0 14px 10px;text-align:right">
          <button
            onclick="openPicksModal(this)"
            data-id="<%= m.id %>"
            data-team-a="<%= m.team_a.replace(/"/g, '&quot;') %>"
            data-team-b="<%= m.team_b.replace(/"/g, '&quot;') %>"
            style="font-size:.7rem;color:var(--muted);background:none;border:none;cursor:pointer;padding:0;text-decoration:underline">
            View all picks →
          </button>
        </div>
        <% } %>

        <%/* ── Inline prediction form ── */%>
        <% if (!m.result && !m.is_locked && !user.is_admin) { %>
        <div id="predict-form-<%= m.id %>" class="predict-form" style="display:none">

          <div class="predict-opts">
            <div class="predict-opt">
              <input type="radio" id="pa_<%= m.id %>" name="pred_<%= m.id %>" value="team_a"
                     <%= m.prediction === 'team_a' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, <%= m.is_knockout ? 'true' : 'false' %>)">
              <label for="pa_<%= m.id %>" title="<%= m.team_a %>"><%= m.team_a %></label>
            </div>
            <% if (!m.is_knockout) { %>
            <div class="predict-opt">
              <input type="radio" id="pd_<%= m.id %>" name="pred_<%= m.id %>" value="draw"
                     <%= m.prediction === 'draw' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, false)">
              <label for="pd_<%= m.id %>">🤝 Draw</label>
            </div>
            <% } %>
            <div class="predict-opt">
              <input type="radio" id="pb_<%= m.id %>" name="pred_<%= m.id %>" value="team_b"
                     <%= m.prediction === 'team_b' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, <%= m.is_knockout ? 'true' : 'false' %>)">
              <label for="pb_<%= m.id %>" title="<%= m.team_b %>"><%= m.team_b %></label>
            </div>
          </div>

          <% if (m.is_knockout) { %>
          <div class="predict-aet">
            <span>Decided in:</span>
            <div>
              <input type="radio" id="a90_<%= m.id %>" name="aet_<%= m.id %>" value="90min"
                     <%= m.aet_prediction === '90min' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, true)">
              <label for="a90_<%= m.id %>">90 min</label>
            </div>
            <div>
              <input type="radio" id="aet_<%= m.id %>" name="aet_<%= m.id %>" value="aet"
                     <%= m.aet_prediction === 'aet' ? 'checked' : '' %>
                     onchange="setPending(<%= m.id %>, true)">
              <label for="aet_<%= m.id %>">AET / Pens</label>
            </div>
          </div>
          <% } %>

          <div style="font-size:.75rem;color:var(--text-dim);margin-top:6px;text-align:center">
            Hit <strong style="color:var(--accent)">Save All</strong> at the top when ready
          </div>

        </div>
        <% } %>

      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<!-- Seed saved predictions for change-detection -->
<script>
const savedPredictions = {
  <% matches.forEach(m => { if (m.prediction) { %>
  <%= m.id %>: { prediction: '<%= m.prediction %>', aet_prediction: <%= m.aet_prediction ? `'${m.aet_prediction}'` : 'null' %> },
  <% } }) %>
};

const pending = {};

function setPending(matchId, isKnockout) {
  const predEl = document.querySelector(`input[name="pred_${matchId}"]:checked`);
  if (!predEl) return;
  const pred = predEl.value;
  let aet = null;
  if (isKnockout) {
    const aetEl = document.querySelector(`input[name="aet_${matchId}"]:checked`);
    aet = aetEl ? aetEl.value : null;
  }
  const saved = savedPredictions[matchId];
  const unchanged = saved && saved.prediction === pred && saved.aet_prediction === aet;
  if (unchanged) { delete pending[matchId]; } else { pending[matchId] = { prediction: pred, aet_prediction: aet }; }
  updateSaveBar();
}

function updateSaveBar() {
  const count = Object.keys(pending).length;
  document.getElementById('save-bar-count').textContent = count;
  document.getElementById('save-bar').style.display = count > 0 ? 'flex' : 'none';
  const btn = document.getElementById('save-bar-btn');
  if (btn) btn.textContent = `💾 Save All (${count})`;
}

async function saveAll() {
  const btn = document.getElementById('save-bar-btn');
  btn.disabled = true; btn.textContent = 'Saving…';
  const predictions = Object.entries(pending).map(([matchId, data]) => ({
    matchId: parseInt(matchId), prediction: data.prediction, aet_prediction: data.aet_prediction
  }));
  try {
    const resp = await fetch('/matches/predict-batch', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ predictions })
    });
    const data = await resp.json();
    if (data.ok) { window.location.reload(); }
    else {
      alert('⚠️ ' + (data.errors || []).join('\n'));
      btn.disabled = false; updateSaveBar();
    }
  } catch (e) {
    alert('Save failed — try again.'); btn.disabled = false; updateSaveBar();
  }
}

function togglePredictForm(id) {
  const form = document.getElementById('predict-form-' + id);
  if (!form) return;
  const isOpen = form.style.display !== 'none';
  document.querySelectorAll('.predict-form').forEach(f => f.style.display = 'none');
  if (!isOpen) { form.style.display = 'block'; form.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }
}

function scrollToRecent() {
  const first = document.querySelector('.match-card[data-played="0"]');
  if (first) { first.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
}

// ── All picks modal ───────────────────────────────────────────────────────────
async function openPicksModal(btn) {
  const matchId = btn.dataset.id;
  const teamA   = btn.dataset.teamA;
  const teamB   = btn.dataset.teamB;

  document.getElementById('picks-modal-title').textContent = teamA + ' vs ' + teamB;
  document.getElementById('picks-modal-body').innerHTML =
    '<div style="text-align:center;padding:24px;color:var(--muted)">Loading…</div>';
  document.getElementById('picks-overlay').style.display = 'block';
  document.getElementById('picks-modal').style.display   = 'block';
  document.body.style.overflow = 'hidden';

  try {
    const r    = await fetch('/api/match/' + matchId + '/predictions');
    const data = await r.json();
    if (!data.ok) {
      document.getElementById('picks-modal-body').innerHTML =
        '<div style="color:var(--muted);text-align:center;padding:20px">Not available.</div>';
      return;
    }
    const result = data.result;
    const rows = data.preds.map((p, i) => {
      let predLabel = '<span style="color:var(--muted)">—</span>';
      let icon = '';
      if (p.prediction) {
        const name = p.prediction === 'team_a' ? teamA : p.prediction === 'draw' ? '🤝 Draw' : teamB;
        predLabel = '<span style="color:var(--text)">' + name + '</span>';
        if (result) icon = p.prediction === result ? '✅' : '❌';
      }
      const bg = i % 2 === 1 ? 'background:rgba(255,255,255,.015)' : '';
      return '<tr style="border-top:1px solid var(--border);' + bg + '">'
        + '<td style="padding:9px 12px;font-weight:500;color:var(--text);font-size:.85rem">' + p.display_name + '</td>'
        + '<td style="padding:9px 12px;font-size:.85rem">' + predLabel + '</td>'
        + '<td style="padding:9px 12px;text-align:center;font-size:.9rem">' + icon + '</td>'
        + '</tr>';
    }).join('');

    document.getElementById('picks-modal-body').innerHTML =
      '<table style="width:100%;border-collapse:collapse">'
      + '<thead><tr style="background:rgba(255,255,255,.04);color:var(--text-dim);font-size:.68rem;text-transform:uppercase;letter-spacing:.04em">'
      + '<th style="padding:8px 12px;text-align:left">Player</th>'
      + '<th style="padding:8px 12px;text-align:left">Pick</th>'
      + '<th style="padding:8px 12px;text-align:center">' + (result ? 'Result' : '') + '</th>'
      + '</tr></thead><tbody>' + rows + '</tbody></table>';
  } catch(e) {
    document.getElementById('picks-modal-body').innerHTML =
      '<div style="color:var(--muted);text-align:center;padding:20px">Error loading picks.</div>';
  }
}

function closePicksModal() {
  document.getElementById('picks-overlay').style.display = 'none';
  document.getElementById('picks-modal').style.display   = 'none';
  document.body.style.overflow = '';
}
</script>

<!-- All picks modal -->
<div id="picks-overlay" onclick="closePicksModal()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:900"></div>
<div id="picks-modal" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:901;background:var(--surface);border-top:1px solid var(--border);border-radius:18px 18px 0 0;max-height:80vh;overflow-y:auto">
  <div style="position:sticky;top:0;background:var(--surface);padding:16px 16px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
    <div id="picks-modal-title" style="font-weight:700;font-size:.95rem;color:var(--text)"></div>
    <button onclick="closePicksModal()" style="background:none;border:none;color:var(--text-dim);font-size:1.3rem;cursor:pointer;line-height:1">✕</button>
  </div>
  <div id="picks-modal-body" style="padding-bottom:16px"></div>
</div>

<%- include('partials/footer') %>

<%- include('../partials/header', { currentPage: '' }) %>
<%- include('../partials/admin-nav', { adminPage: 'dashboard' }) %>

<div class="page">
  <div class="container">

    <% if (flashSuccess) { %><div class="flash flash-success">✅ <%- flashSuccess %></div><% } %>
    <% if (flashError)   { %><div class="flash flash-error">⚠️ <%- flashError %></div><% } %>

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px">
      <h1 style="font-size:1.5rem;font-weight:800">⚙️ Admin Dashboard</h1>
      <span class="admin-badge">Admin</span>
    </div>

    <!-- Stats -->
    <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(140px,1fr))">
      <div class="stat-card">
        <div class="stat-value"><%= stats.totalUsers %></div>
        <div class="stat-label">Players</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.totalMatches %></div>
        <div class="stat-label">Matches</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:var(--green)"><%= stats.resultsIn %></div>
        <div class="stat-label">Results In</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:var(--red)"><%= stats.lockedCount %></div>
        <div class="stat-label">Locked</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" style="color:var(--blue)"><%= stats.totalPreds %></div>
        <div class="stat-label">Total Predictions</div>
      </div>
    </div>

    <!-- Quick actions -->
    <div style="display:grid;gap:20px;grid-template-columns:1fr 1fr;margin-bottom:28px" class="admin-2col">
      <!-- Pending results -->
      <div>
        <div class="section-header">
          <div class="section-title">⏳ Awaiting Results</div>
          <a href="/admin/results" class="btn btn-primary btn-sm">Enter Results →</a>
        </div>
        <% if (pendingResults.length === 0) { %>
          <div class="card text-center text-muted" style="padding:24px">All played matches have results ✅</div>
        <% } else { %>
        <div class="card" style="padding:0;overflow:hidden">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Match</th>
                <th>Round</th>
                <th>Time (KWT)</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% pendingResults.forEach(m => { %>
              <tr>
                <td><strong><%= m.team_a %></strong> vs <strong><%= m.team_b %></strong></td>
                <td><span class="badge badge-<%= m.round === 'group' ? 'group' : 'knockout' %>"><%= m.round %></span></td>
                <td style="font-size:.8rem;color:var(--text-dim)"><%= m.match_time_kwt %></td>
                <td><a href="/admin/results?round=<%= m.round %>" class="btn btn-sm btn-primary">Enter</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- Recent admin activity -->
      <div>
        <div class="section-header">
          <div class="section-title">📋 Recent Activity</div>
          <a href="/admin/log" class="btn btn-secondary btn-sm">Full Log</a>
        </div>
        <div class="card" style="padding:0;overflow:hidden">
          <% if (recentLog.length === 0) { %>
            <div class="text-center text-muted" style="padding:24px;font-size:.85rem">No activity yet.</div>
          <% } else { %>
          <table class="admin-table">
            <thead><tr><th>Admin</th><th>Action</th><th>Time</th></tr></thead>
            <tbody>
              <% recentLog.forEach(l => { %>
              <tr>
                <td style="font-size:.8rem"><%= l.username %></td>
                <td style="font-size:.8rem;color:var(--text-dim)">
                  <strong style="color:var(--text)"><%= l.action %></strong>
                  <% if (l.details) { %><div style="font-size:.72rem;color:var(--muted)"><%= l.details %></div><% } %>
                </td>
                <td style="font-size:.73rem;color:var(--muted);white-space:nowrap"><%= l.created_at.slice(0,16).replace('T',' ') %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Lock / Unlock by Round + Matchday -->
    <div class="card" style="margin-bottom:20px">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:16px">
        <div class="card-title" style="margin:0">🔒 Lock / Unlock Predictions</div>
        <!-- Sync Scores button -->
        <form method="POST" action="/admin/sync-scores" onsubmit="this.querySelector('button').textContent='Syncing…';this.querySelector('button').disabled=true">
          <button type="submit" class="btn btn-primary" style="background:#059669;border-color:#059669">
            🔄 Sync Scores from ESPN
          </button>
        </form>
      </div>

      <table style="width:100%;border-collapse:collapse;font-size:.85rem">
        <thead>
          <tr style="background:rgba(255,255,255,.04);color:var(--text-dim);font-size:.72rem;text-transform:uppercase;letter-spacing:.04em">
            <th style="padding:8px 12px;text-align:left">Round / Matchday</th>
            <th style="padding:8px 12px;text-align:center">Status</th>
            <th style="padding:8px 12px;text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <%
            const rounds = [
              { key: 'group_md1', label: '⚽ Group Stage — Matchday 1', sub: 'Jun 11–17' },
              { key: 'group_md2', label: '⚽ Group Stage — Matchday 2', sub: 'Jun 18–23' },
              { key: 'group_md3', label: '⚽ Group Stage — Matchday 3', sub: 'Jun 24+' },
              { key: 'r32',   label: '🏆 Round of 32',    sub: '' },
              { key: 'r16',   label: '🏆 Round of 16',    sub: '' },
              { key: 'qf',    label: '🏆 Quarterfinals',  sub: '' },
              { key: 'sf',    label: '🏆 Semifinals',     sub: '' },
              { key: '3rd',   label: '🏆 Third Place',    sub: '' },
              { key: 'final', label: '🏆 Final',          sub: '' },
            ];
          %>
          <% rounds.forEach((r, i) => {
            const ls = lockStatus[r.key] || { total: 0, locked: 0 };
            const allLocked = ls.total > 0 && ls.locked === ls.total;
            const noneLocked = ls.locked === 0;
          %>
          <tr style="border-top:1px solid var(--border)<%= i%2===1 ? ';background:rgba(255,255,255,.015)' : '' %>">
            <td style="padding:10px 12px">
              <div style="font-weight:600;color:var(--text)"><%= r.label %></div>
              <% if (r.sub) { %><div style="font-size:.72rem;color:var(--text-dim)"><%= r.sub %></div><% } %>
            </td>
            <td style="padding:10px 12px;text-align:center">
              <% if (ls.total === 0) { %>
                <span style="font-size:.78rem;color:var(--muted)">—</span>
              <% } else if (allLocked) { %>
                <span style="font-size:.78rem;color:#f87171;font-weight:600">🔒 All locked (<%= ls.total %>)</span>
              <% } else if (noneLocked) { %>
                <span style="font-size:.78rem;color:var(--green);font-weight:600">🔓 Open (<%= ls.total %>)</span>
              <% } else { %>
                <span style="font-size:.78rem;color:var(--gold)"><%= ls.locked %>/<%= ls.total %> locked</span>
              <% } %>
            </td>
            <td style="padding:10px 12px;text-align:right">
              <% if (ls.total > 0) { %>
              <form method="POST" action="/admin/matches/lock-round" style="display:inline-flex;gap:6px">
                <input type="hidden" name="round" value="<%= r.key %>">
                <button type="submit" name="action" value="lock" class="btn btn-danger btn-sm">🔒 Lock</button>
                <button type="submit" name="action" value="unlock" class="btn btn-success btn-sm">🔓 Unlock</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>
</div>

<style>
@media (max-width: 700px) { .admin-2col { grid-template-columns: 1fr !important; } }
</style>

<%- include('../partials/footer') %>

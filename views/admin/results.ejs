<%- include('../partials/header', { currentPage: '' }) %>
<%- include('../partials/admin-nav', { adminPage: 'results' }) %>

<div class="page">
  <div class="container">

    <% if (flashSuccess) { %><div class="flash flash-success">✅ <%- flashSuccess %></div><% } %>
    <% if (flashError)   { %><div class="flash flash-error">⚠️ <%- flashError %></div><% } %>

    <div class="section-header">
      <div class="section-title">📊 Enter Match Results</div>
    </div>

    <!-- Round filter -->
    <div class="tabs mb-16">
      <a href="/admin/results" class="tab-btn <%= filter === 'all' ? 'active' : '' %>">All</a>
      <a href="/admin/results?round=group" class="tab-btn <%= filter === 'group' ? 'active' : '' %>">Group</a>
      <a href="/admin/results?round=r32"   class="tab-btn <%= filter === 'r32'   ? 'active' : '' %>">R32</a>
      <a href="/admin/results?round=r16"   class="tab-btn <%= filter === 'r16'   ? 'active' : '' %>">R16</a>
      <a href="/admin/results?round=qf"    class="tab-btn <%= filter === 'qf'    ? 'active' : '' %>">QF</a>
      <a href="/admin/results?round=sf"    class="tab-btn <%= filter === 'sf'    ? 'active' : '' %>">SF</a>
      <a href="/admin/results?round=final" class="tab-btn <%= filter === 'final' ? 'active' : '' %>">Final</a>
    </div>

    <div class="card" style="padding:0;overflow:hidden">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Match</th>
            <th>Round</th>
            <th>Kickoff (KWT)</th>
            <th>Result</th>
            <th>AET?</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% matches.forEach(m => { %>
          <tr>
            <td>
              <strong><%= m.team_a %></strong>
              <span style="color:var(--muted)"> vs </span>
              <strong><%= m.team_b %></strong>
            </td>
            <td>
              <span class="badge badge-<%= m.round === 'group' ? 'group' : 'knockout' %>"><%= m.round %></span>
            </td>
            <td style="font-size:.8rem;color:var(--text-dim);white-space:nowrap"><%= m.match_time_kwt %></td>
            <td>
              <% if (m.result) { %>
                <span class="result-<%= m.result %>">
                  <%= m.result === 'team_a' ? m.team_a : (m.result === 'draw' ? 'Draw' : m.team_b) %>
                </span>
              <% } else { %>
                <span class="text-muted">—</span>
              <% } %>
            </td>
            <td style="font-size:.82rem;color:var(--text-dim)">
              <%= m.aet_result === 'aet' ? '⏱️ AET' : (m.aet_result === '90min' ? '90 min' : '—') %>
            </td>
            <td>
              <button class="btn btn-sm btn-primary" onclick="openResultModal(<%= JSON.stringify({
                id: m.id,
                team_a: m.team_a,
                team_b: m.team_b,
                is_knockout: m.is_knockout,
                result: m.result,
                aet_result: m.aet_result,
                score_a: m.score_a !== undefined ? m.score_a : null,
                score_b: m.score_b !== undefined ? m.score_b : null
              }) %>)">
                <%= m.result ? '✏️ Edit' : '+ Enter' %>
              </button>
              <% if (m.result) { %>
              <form method="POST" action="/admin/results/<%= m.id %>/delete" style="display:inline" onsubmit="return confirm('Remove this result?')">
                <button class="btn btn-sm btn-danger">✕</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Result entry modal -->
<div id="resultModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;align-items:center;justify-content:center">
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:28px;width:100%;max-width:440px;margin:16px">
    <h3 style="margin-bottom:20px;font-size:1rem" id="modalTitle">Enter Result</h3>
    <form method="POST" id="resultForm">
      <div class="form-group">
        <label class="form-label">Score (optional)</label>
        <div style="display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:8px">
          <input type="number" name="score_a" id="score_a" class="form-control" min="0" max="99" placeholder="0" style="text-align:center">
          <span style="color:var(--text-dim);font-weight:700;padding:0 4px">–</span>
          <input type="number" name="score_b" id="score_b" class="form-control" min="0" max="99" placeholder="0" style="text-align:center">
        </div>
        <div id="scoreTeamLabels" style="display:grid;grid-template-columns:1fr auto 1fr;font-size:.72rem;color:var(--text-dim);margin-top:3px;text-align:center">
          <span id="scoreLabel_a"></span><span></span><span id="scoreLabel_b"></span>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Result (winner)</label>
        <select name="result" id="resultSelect" class="form-control" required>
          <option value="">— Select result —</option>
          <option value="team_a" id="opt_team_a">Team A wins</option>
          <option value="draw">Draw</option>
          <option value="team_b" id="opt_team_b">Team B wins</option>
        </select>
      </div>
      <div class="form-group" id="aetGroup" style="display:none">
        <label class="form-label">Decided in:</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
          <label style="display:flex;align-items:center;gap:8px;padding:10px;border:1px solid var(--border);border-radius:8px;cursor:pointer">
            <input type="radio" name="aet_result" value="90min"> 90 Minutes
          </label>
          <label style="display:flex;align-items:center;gap:8px;padding:10px;border:1px solid var(--border);border-radius:8px;cursor:pointer">
            <input type="radio" name="aet_result" value="aet"> AET / Penalties
          </label>
        </div>
      </div>
      <div style="display:flex;gap:10px;margin-top:20px">
        <button type="submit" class="btn btn-primary" style="flex:1">Save Result</button>
        <button type="button" class="btn btn-secondary" onclick="closeModal()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function openResultModal(match) {
  document.getElementById('modalTitle').textContent = match.team_a + ' vs ' + match.team_b;
  document.getElementById('opt_team_a').textContent = match.team_a + ' wins';
  document.getElementById('opt_team_b').textContent = match.team_b + ' wins';
  document.getElementById('scoreLabel_a').textContent = match.team_a;
  document.getElementById('scoreLabel_b').textContent = match.team_b;
  document.getElementById('score_a').value = match.score_a !== null ? match.score_a : '';
  document.getElementById('score_b').value = match.score_b !== null ? match.score_b : '';
  document.getElementById('resultSelect').value = match.result || '';
  document.getElementById('resultForm').action = '/admin/results/' + match.id;
  const aetGroup = document.getElementById('aetGroup');
  const optDraw = document.querySelector('#resultSelect option[value="draw"]');
  if (match.is_knockout) {
    optDraw.disabled = true;
    aetGroup.style.display = 'block';
    if (match.aet_result) {
      document.querySelector('input[name="aet_result"][value="' + match.aet_result + '"]').checked = true;
    }
  } else {
    optDraw.disabled = false;
    aetGroup.style.display = 'none';
  }
  document.getElementById('resultModal').style.display = 'flex';
}
function closeModal() { document.getElementById('resultModal').style.display = 'none'; }
document.getElementById('resultModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });
</script>

<%- include('../partials/footer') %>

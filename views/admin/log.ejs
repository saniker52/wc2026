<%- include('../partials/header', { currentPage: '' }) %>
<%- include('../partials/admin-nav', { adminPage: 'log' }) %>

<div class="page">
  <div class="container">
    <div class="section-title mb-16">📋 Admin Audit Log (last 100)</div>
    <div class="card" style="padding:0;overflow:hidden">
      <table class="admin-table">
        <thead>
          <tr><th>Time</th><th>Admin</th><th>Action</th><th>Details</th></tr>
        </thead>
        <tbody>
          <% logs.forEach(l => { %>
          <tr>
            <td style="font-size:.77rem;color:var(--muted);white-space:nowrap"><%= l.created_at.slice(0,16).replace('T',' ') %></td>
            <td style="font-size:.83rem"><%= l.username %></td>
            <td style="font-weight:700;font-size:.83rem;color:var(--gold)"><%= l.action %></td>
            <td style="font-size:.82rem;color:var(--text-dim)"><%= l.details || '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
